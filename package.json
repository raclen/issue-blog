{
  "name": "issue-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A Cloudflare-deployable Astro blog that syncs posts from GitHub Issues.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "sync:issues": "node scripts/sync-issues.js",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/rss": "^4.0.18",
    "astro": "^7.0.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "wrangler": "^4.105.0"
  }
}
